{
  "$schema": "https://biomejs.dev/schemas/2.5.1/schema.json",
  "assist": {
    "actions": {
      "source": {
        "organizeImports": "on",
        "useSortedAttributes": "on",
        "useSortedInterfaceMembers": "on",
        "useSortedKeys": "on",
        "useSortedProperties": "on",
        "useSortedTypeFields": "on"
      }
    },
    "includes": ["src/**"]
  },
  "formatter": {
    "attributePosition": "auto",
    "bracketSpacing": true,
    "formatWithErrors": false,
    "indentStyle": "space"
  },
  "linter": {
    "includes": ["src/**"],
    "rules": {
      "preset": "recommended"
    }
  }
}
